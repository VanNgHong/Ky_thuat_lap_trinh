{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Quiz Program",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++17",
                "-g",
                "-Wall",

                "-I${workspaceFolder}/include",

                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/Menu.cpp",
                "${workspaceFolder}/src/Exam.cpp",
                "${workspaceFolder}/src/History.cpp",
                "${workspaceFolder}/src/QuestionBank.cpp",

                "-o",
                "${workspaceFolder}/quiz_program.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}